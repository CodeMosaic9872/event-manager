DATABASE_URL="postgresql://postgres:postgres@localhost:5432/event_marketplace?schema=public"
PORT=3001
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"
JWT_ACCESS_SECRET="replace_with_strong_access_secret"
JWT_REFRESH_SECRET="replace_with_strong_refresh_secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
AI_PROVIDER_TIMEOUT_MS=6000
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
DO_SPACES_ENDPOINT="fra1.digitaloceanspaces.com"
DO_SPACES_REGION="fra1"
DO_SPACES_BUCKET="event-marketplace-media"
DO_SPACES_KEY="replace_with_spaces_key"
DO_SPACES_SECRET="replace_with_spaces_secret"
DO_SPACES_PUBLIC_BASE_URL="https://event-marketplace-media.fra1.digitaloceanspaces.com"
NOTIFICATION_PROVIDER="mock"
NOTIFICATION_SMTP_HOST=""
# Use 465 for implicit TLS (SSL); app sets secure=true when port is 465. Common alternative: 587 + STARTTLS.
NOTIFICATION_SMTP_PORT=587
NOTIFICATION_SMTP_USER=""
NOTIFICATION_SMTP_PASS=""
NOTIFICATION_SMTP_FROM=""
NOTIFICATION_TWILIO_ACCOUNT_SID=""
NOTIFICATION_TWILIO_AUTH_TOKEN=""
NOTIFICATION_TWILIO_FROM=""
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
NOTIFICATION_MAX_ATTEMPTS=3
NOTIFICATION_RETRY_BASE_MS=1000
# When true, processes queued EMAIL/PUSH/SMS notifications on an interval (required for automated sends).
NOTIFICATION_WORKER_ENABLED=false
NOTIFICATION_WORKER_INTERVAL_MS=15000
# Scheduled reminders (AI limit, favorites, profile-view follow-up, draft jobs, user/supplier inactivity,
# subscription window, admin digests / AI failure alerts).
NOTIFICATION_REMINDER_WORKER_ENABLED=false
NOTIFICATION_REMINDER_INTERVAL_MS=3600000
# Ops email for optional admin digests (requires NOTIFICATION_REMINDER_WORKER_ENABLED).
ADMIN_ALERT_EMAIL=
ADMIN_INCOMPLETE_DIGEST_ENABLED=false
ADMIN_LEADS_DIGEST_ENABLED=false
ADMIN_INACTIVE_SUPPLIERS_DIGEST_ENABLED=false
ADMIN_AI_FAILURE_ALERT_ENABLED=false
ADMIN_AI_FAILURE_WINDOW_HOURS=24
ADMIN_AI_FAILURE_MIN_COUNT=25
# When true, /auth/request-otp does NOT call 019sms; /auth/verify-otp accepts AUTH_FIXED_OTP_CODE.
# Use this in dev/local until real 019sms credentials are provisioned.
AUTH_FIXED_OTP_ENABLED=true
AUTH_FIXED_OTP_CODE=123456
# 019sms provider config (only required when AUTH_FIXED_OTP_ENABLED=false).
# Use https://019sms.co.il/api/test as the base URL during development to validate payloads
# without actually sending SMS.
SMS_019_API_BASE_URL=https://019sms.co.il/api
SMS_019_USERNAME=
SMS_019_TOKEN=
SMS_019_SOURCE=
SMS_019_APP_ID=1
OTP_VALID_MINUTES=5
OTP_MAX_ATTEMPTS=5
# Optional dedicated sender for OTP emails. Falls back to NOTIFICATION_SMTP_FROM.
OTP_EMAIL_FROM=

# Enables POST /v1/notifications/test-email when set; send matching X-Email-Test-Secret header.
EMAIL_TEST_SECRET=

# --- CardCom (BillGold Low Profile) ---
# SOAP endpoint (default: BillGoldService.asmx on secure.cardcom.solutions).
# CARDCOM_SOAP_URL=https://secure.cardcom.solutions/Interface/BillGoldService.asmx
# Terminal number + API user name from CardCom (do not commit real values to git).
CARDCOM_TERMINAL_NUMBER=
CARDCOM_USERNAME=
# Optional: API password (CardCom: refunds with tokens, invoice-only flows, etc.). Not used by current low-profile SOAP envelope.
# CARDCOM_API_PASSWORD=
# Optional BillGold UserID field required by CreateLowProfileDeal (often 0).
# CARDCOM_BILLGOLD_USER_ID=0
# Public base URL of THIS API (no trailing slash). Builds IndicatorUrl: {base}/v1/webhooks/cardcom/indicator
# Staging backend (EasyPanel): use this when the API runs there so CardCom can POST the indicator to your server.
CARDCOM_PUBLIC_APP_BASE_URL=https://event-backend.b77xp9.easypanel.host
# Where CardCom redirects the shopper after pay (staging Next.js — not the API host).
CARDCOM_SUCCESS_REDIRECT_URL=https://event-frontend.b77xp9.easypanel.host/join-supplier/step-5?pay=ok
CARDCOM_ERROR_REDIRECT_URL=https://event-frontend.b77xp9.easypanel.host/join-supplier/step-5?pay=err
CARDCOM_CANCEL_REDIRECT_URL=https://event-frontend.b77xp9.easypanel.host/join-supplier/step-5?pay=cancel
# Local dev examples (uncomment if you run API on :3001 and app on :3000):
# CARDCOM_PUBLIC_APP_BASE_URL=http://localhost:3001
# CARDCOM_SUCCESS_REDIRECT_URL=http://localhost:3000/join-supplier/step-5?pay=ok
# CARDCOM_ERROR_REDIRECT_URL=http://localhost:3000/join-supplier/step-5?pay=err
# CARDCOM_CANCEL_REDIRECT_URL=http://localhost:3000/join-supplier/step-5?pay=cancel
# Optional: append ?s=... to IndicatorUrl; webhook rejects requests when mismatch.
# CARDCOM_WEBHOOK_SHARED_SECRET=
# Optional checkout language sent to CardCom (default he).
# CARDCOM_CHECKOUT_LANGUAGE=he
# CARDCOM_HTTP_TIMEOUT_MS=20000

# Subscription renewal worker (token-based recurring billing)
PAYMENT_RENEWAL_WORKER_ENABLED=false
PAYMENT_RENEWAL_WORKER_INTERVAL_MS=600000
