generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum PlatformRole {
  USER
  SUPPLIER
  ADMIN
}

enum SupplierApprovalStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum JobApplicationStatus {
  SUBMITTED
  SHORTLISTED
  REJECTED
  WITHDRAWN
}

enum AiConversationStatus {
  ACTIVE
  GATED_REGISTRATION_REQUIRED
  CLOSED
}

enum AiRole {
  USER
  ASSISTANT
  SYSTEM
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id               String     @id @default(cuid())
  email            String?    @unique
  phone            String?    @unique
  passwordHash     String?
  refreshTokenHash String?
  status           UserStatus @default(ACTIVE)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?

  roles         UserRole[]
  supplier      Supplier?
  jobPosts      JobPost[]
  conversations AiConversation[]
  favorites     FavoriteSupplier[]
}

model UserRole {
  id        String       @id @default(cuid())
  userId    String
  role      PlatformRole
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
}

model AnonymousSession {
  id              String   @id @default(cuid())
  token           String   @unique
  fingerprintHash String?
  ipHash          String?
  createdAt       DateTime @default(now())
  lastSeenAt      DateTime @default(now())

  conversations AiConversation[]
  favorites     FavoriteSupplier[]
}

model Supplier {
  id             String                 @id @default(cuid())
  ownerUserId    String                 @unique
  businessName   String
  slug           String                 @unique
  description    String?
  approvalStatus SupplierApprovalStatus @default(DRAFT)
  isActive       Boolean                @default(true)
  isVerified     Boolean                @default(false)
  ratingAvg      Decimal?               @db.Decimal(3, 2)
  ratingCount    Int                    @default(0)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  deletedAt      DateTime?

  owner           User                      @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  categories      SupplierCategory[]
  serviceAreas    SupplierServiceArea[]
  media           SupplierMedia[]
  socialLinks     SupplierSocialLink[]
  attributes      SupplierAttribute?
  draft           SupplierDraft?
  approvalHistory SupplierApprovalHistory[]
  applications    JobApplication[]
  favorites       FavoriteSupplier[]
}

model SupplierDraft {
  id                String   @id @default(cuid())
  supplierId        String   @unique
  stepKey           String
  completionPercent Int      @default(0)
  payloadJson       Json
  version           Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lastAutosaveAt    DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model SupplierApprovalHistory {
  id           String                 @id @default(cuid())
  supplierId   String
  fromStatus   SupplierApprovalStatus
  toStatus     SupplierApprovalStatus
  reason       String?
  actorAdminId String?
  createdAt    DateTime               @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model EventType {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mappings EventCategorySubcategoryMap[]
}

model Category {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subcategories      Subcategory[]
  filters            FilterDefinition[]
  supplierCategories SupplierCategory[]
  mappings           EventCategorySubcategoryMap[]
}

model Subcategory {
  id         String   @id @default(cuid())
  categoryId String
  key        String
  name       String
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category                      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  mappings EventCategorySubcategoryMap[]

  @@unique([categoryId, key])
}

model EventCategorySubcategoryMap {
  id            String   @id @default(cuid())
  eventTypeId   String
  categoryId    String
  subcategoryId String
  priority      Int      @default(0)
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  eventType   EventType   @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subcategory Subcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)

  @@unique([eventTypeId, categoryId, subcategoryId])
  @@index([eventTypeId, categoryId])
}

model FilterDefinition {
  id          String   @id @default(cuid())
  scope       String
  categoryId  String?
  key         String
  label       String
  type        String
  optionsJson Json?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([scope, categoryId, key])
}

model SupplierCategory {
  id            String   @id @default(cuid())
  supplierId    String
  categoryId    String
  subcategoryId String?
  createdAt     DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([supplierId, categoryId])
}

model SupplierServiceArea {
  id         String  @id @default(cuid())
  supplierId String
  regionCode String
  cityCode   String?

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model SupplierMedia {
  id           String   @id @default(cuid())
  supplierId   String
  mediaType    String
  url          String
  sortOrder    Int      @default(0)
  metadataJson Json?
  createdAt    DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model SupplierSocialLink {
  id         String @id @default(cuid())
  supplierId String
  platform   String
  url        String

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model SupplierAttribute {
  id                 String   @id @default(cuid())
  supplierId         String   @unique
  insurance          Boolean?
  accessibility      Boolean?
  kosherOptions      Json?
  languagesJson      Json?
  govSupplierFlags   Json?
  workingDaysJson    Json?
  certificationsJson Json?

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model JobPost {
  id           String    @id @default(cuid())
  ownerUserId  String
  eventTypeId  String?
  title        String
  description  String
  eventDate    DateTime?
  locationText String?
  budgetMin    Int?
  budgetMax    Int?
  guestCount   Int?
  status       JobStatus @default(DRAFT)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  publishedAt  DateTime?

  owner        User             @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  applications JobApplication[]
}

model JobApplication {
  id          String               @id @default(cuid())
  jobPostId   String
  supplierId  String
  message     String?
  status      JobApplicationStatus @default(SUBMITTED)
  submittedAt DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  jobPost  JobPost  @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([jobPostId, supplierId])
}

model AiConversation {
  id                 String               @id @default(cuid())
  userId             String?
  anonymousSessionId String?
  status             AiConversationStatus @default(ACTIVE)
  contextJson        Json?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  user             User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  anonymousSession AnonymousSession? @relation(fields: [anonymousSessionId], references: [id], onDelete: SetNull)
  messages         AiMessage[]
}

model AiMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           AiRole
  content        String
  tokenCount     Int?
  latencyMs      Int?
  createdAt      DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model AiUsageCounter {
  id                 String    @id @default(cuid())
  userId             String?   @unique
  anonymousSessionId String?   @unique
  messageCount       Int       @default(0)
  periodStartAt      DateTime  @default(now())
  periodEndAt        DateTime?
  updatedAt          DateTime  @updatedAt
}

model FavoriteSupplier {
  id                 String   @id @default(cuid())
  userId             String?
  anonymousSessionId String?
  supplierId         String
  createdAt          DateTime @default(now())

  user             User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  anonymousSession AnonymousSession? @relation(fields: [anonymousSessionId], references: [id], onDelete: SetNull)
  supplier         Supplier          @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([userId, supplierId])
  @@unique([anonymousSessionId, supplierId])
}

model NotificationTemplate {
  id              String              @id @default(cuid())
  key             String              @unique
  channel         NotificationChannel
  subjectTemplate String?
  bodyTemplate    String
  isActive        Boolean             @default(true)
  version         Int                 @default(1)
  createdAt       DateTime            @default(now())
}

model Notification {
  id                  String              @id @default(cuid())
  recipientUserId     String?
  recipientSupplierId String?
  channel             NotificationChannel
  templateKey         String
  payloadJson         Json
  status              NotificationStatus  @default(PENDING)
  providerMessageId   String?
  errorCode           String?
  scheduledAt         DateTime?
  sentAt              DateTime?
  createdAt           DateTime            @default(now())
}
